// Prisma schema for RK Web Monitor
// Хранилище: SQLite (один файл rkwebmon.db рядом с приложением — удобно для бэкапа)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Пользователь системы. Роли: admin / manager / viewer
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  displayName   String
  role          String   @default("viewer") // admin | manager | viewer
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  messages      StaffMessage[]
}

/// Сессия пользователя (cookie-based auth)
model Session {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  userAgent     String?

  @@index([userId])
  @@index([expiresAt]) // для быстрой очистки истёкших сессий
}

/// RK7-сервер для мониторинга
model Server {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("demo") // demo | tcp | http
  address       String   // IP:порт (для tcp) или URL (для http) или путь к папке (для demo)
  cryptKey      String?
  username      String?  // логин для подключения к RK7
  password      String?  // пароль (хранится в открытом виде — это пароль RK7, не пользователя)
  enabled       Boolean  @default(true)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled])
}

/// Сообщения персоналу (история)
model StaffMessage {
  id            String   @id @default(cuid())
  recipient     String
  recipientCode Int?
  text          String
  sentById      String?
  sentBy        User?    @relation(fields: [sentById], references: [id], onDelete: SetNull)
  sentAt        DateTime @default(now())
  status        String   @default("sent") // sent | queued | failed

  @@index([sentAt]) // для сортировки по дате
  @@index([sentById])
}

/// Системные настройки (key-value). Хранит порт, host и др.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
